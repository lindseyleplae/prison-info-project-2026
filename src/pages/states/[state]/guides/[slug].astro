---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../../../layouts/GuideLayout.astro';

export async function getStaticPaths() {
  const [states, guides, nationalGuides] = await Promise.all([
    getCollection('states', ({ data }) => !data.draft),
    getCollection('state-guides', ({ data }) => !data.draft),
    getCollection('national-guides', ({ data }) => !data.draft)
  ]);

  const stateByCode = new Map(states.map((entry) => [entry.data.state, entry]));
  const nationalGuideBySlug = new Map(nationalGuides.map((guide) => [guide.data.slug, guide]));

  return guides
    .map((entry) => {
      const state = stateByCode.get(entry.data.state);
      if (!state) {
        return undefined;
      }

      const national = entry.data.relatedNationalGuide
        ? nationalGuideBySlug.get(entry.data.relatedNationalGuide)
        : undefined;

      return {
        params: {
          state: state.data.slug,
          slug: entry.data.topic ?? entry.data.slug
        },
        props: {
          entry,
          stateTitle: state.data.title,
          relatedNationalGuide: national
            ? { title: national.data.title, href: `/guides/${national.data.slug}/` }
            : undefined
        }
      };
    })
    .filter(Boolean);
}

const { entry, stateTitle, relatedNationalGuide } = Astro.props;
const { Content, headings } = await render(entry);
---

<GuideLayout
  title={entry.data.title}
  description={entry.data.description ?? entry.data.summary}
  headings={headings}
  stateLabel={stateTitle}
  lastReviewed={entry.data.lastReviewed}
  sources={entry.data.sources}
  relatedNationalGuide={relatedNationalGuide}
>
  <Content />
</GuideLayout>
