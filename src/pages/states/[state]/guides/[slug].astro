---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../../../layouts/GuideLayout.astro';

export async function getStaticPaths() {
  const [states, guides] = await Promise.all([
    getCollection('states', ({ data }) => !data.draft),
    getCollection('state-guides', ({ data }) => !data.draft)
  ]);

  const stateByCode = new Map(states.map((entry) => [entry.data.state, entry]));

  return guides
    .map((entry) => {
      const state = stateByCode.get(entry.data.state);
      if (!state) {
        return undefined;
      }

      return {
        params: {
          state: state.data.slug,
          slug: entry.data.topic ?? entry.data.slug
        },
        props: {
          entry,
          stateTitle: state.data.title
        }
      };
    })
    .filter(Boolean);
}

const { entry, stateTitle } = Astro.props;
const { Content, headings } = await render(entry);
---

<GuideLayout
  title={entry.data.title}
  description={entry.data.description ?? entry.data.summary}
  headings={headings}
  stateLabel={stateTitle}
  lastReviewed={entry.data.lastReviewed}
>
  <Content />
</GuideLayout>
