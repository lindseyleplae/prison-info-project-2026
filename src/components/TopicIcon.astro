---
// Small monochrome line icons for the six recurring guide topics, keyed by
// the `icon` names in src/data/topics.ts. Decorative only (aria-hidden) —
// the adjacent text always carries the meaning. Stroke uses currentColor so
// the surrounding CSS color token controls the rendered color.
const { name } = Astro.props as { name?: string };
---

{name && (
  <svg
    class="topic-icon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    focusable="false"
  >
    {name === 'door-open' && (
      <>
        <path d="M13 4h3a2 2 0 0 1 2 2v14" />
        <path d="M2 20h20" />
        <path d="M13 20.5V4.6a1 1 0 0 0-1.2-1l-5.3 1.3A2 2 0 0 0 5 6.8V20" />
        <circle cx="10" cy="12" r="0.5" fill="currentColor" />
      </>
    )}
    {name === 'mailbox' && (
      <>
        <rect x="2" y="4" width="20" height="16" rx="2" />
        <path d="m2 7 10 7 10-7" />
      </>
    )}
    {name === 'phone' && (
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
    )}
    {name === 'wallet' && (
      <>
        <circle cx="12" cy="12" r="9" />
        <path d="M12 6.5v11" />
        <path d="M15 9c0-1.1-1.34-2-3-2s-3 .9-3 2 1.04 1.8 3 2.2 3 1.1 3 2.3-1.34 2-3 2-3-.9-3-2" />
      </>
    )}
    {name === 'clipboard' && (
      <>
        <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
        <rect x="8" y="2" width="8" height="4" rx="1" />
        <path d="M12 10v6" />
        <path d="M9 13h6" />
      </>
    )}
    {name === 'arrows-right-left' && (
      <>
        <path d="m16 3 4 4-4 4" />
        <path d="M20 7H4" />
        <path d="m8 21-4-4 4-4" />
        <path d="M4 17h16" />
      </>
    )}
  </svg>
)}
