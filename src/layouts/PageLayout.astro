---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { createBreadcrumbStructuredData } from '../lib/seo';

const {
  title,
  description
} = Astro.props as {
  title: string;
  description?: string;
};
---

<BaseLayout
  title={title}
  description={description}
  structuredData={[
    createBreadcrumbStructuredData([
      { label: 'Home', href: '/' },
      { label: title, href: Astro.url.pathname }
    ])
  ]}
>
  <div class="container">
    <article class="page-content content-width">
      <Breadcrumbs pageTitle={title} />
      <header class="page-header">
        <h1>{title}</h1>
        {description && <p class="subtitle">{description}</p>}
      </header>
      <slot />
    </article>
  </div>
</BaseLayout>
