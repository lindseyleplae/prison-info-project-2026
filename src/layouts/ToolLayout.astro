---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { createBreadcrumbStructuredData } from '../lib/seo';

const {
  title,
  description,
  updatedAt
} = Astro.props as {
  title: string;
  description?: string;
  updatedAt?: Date;
};
---

<BaseLayout
  title={title}
  description={description}
  structuredData={[
    createBreadcrumbStructuredData([
      { label: 'Home', href: '/' },
      { label: 'Tools' },
      { label: title, href: Astro.url.pathname }
    ])
  ]}
>
  <div class="container">
    <article class="tool-content content-width">
      <Breadcrumbs pageTitle={title} />
      <header class="page-header">
        <h1>{title}</h1>
        {description && <p class="subtitle">{description}</p>}
        {updatedAt && <p class="meta">Updated: {updatedAt.toISOString().slice(0, 10)}</p>}
        <p><button class="button" type="button" onclick="window.print()">Print this page</button></p>
      </header>
      <slot />
    </article>
  </div>
</BaseLayout>
